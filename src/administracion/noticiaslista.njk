---
layout: layouts/base.njk
title: Gestión de Noticias - Agente24
permalink: /administracion/noticiaslista/
robots: noindex, nofollow
eleventyExcludeFromCollections: true
---

<style>
.layout-constrain { max-width: 1000px !important; }

.curador-container { width: 100%; padding: 20px 0; }
.curador-header { margin-bottom: 24px; }
.curador-title { font-size: 24px; font-weight: 900; color: var(--text-main); margin: 0 0 8px 0; }
.curador-subtitle { color: var(--text-sec); font-size: 14px; margin: 0; }

/* Filtros */
.filters-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 24px;
    padding: 14px;
    background-color: var(--card-hover);
    border-radius: 10px;
    border: 1px solid var(--border-color);
    align-items: center;
}
.filters-bar select, .filters-bar button {
    padding: 7px 12px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 600;
    border: 1px solid var(--border-color);
    background-color: var(--bg-color);
    color: var(--text-main);
    cursor: pointer;
}
.filters-bar select:focus { outline: none; border-color: var(--accent); }
.filters-bar label { font-size: 13px; color: var(--text-sec); font-weight: 600; }
.filter-group { display: flex; align-items: center; gap: 6px; }
.filter-divider { width: 1px; height: 28px; background: var(--border-color); margin: 0 4px; }

/* Cards */
.article-list { display: flex; flex-direction: column; gap: 20px; }

.article-card {
    border-radius: 12px;
    padding: 16px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    border: 1px solid var(--border-color);
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
    cursor: pointer;
}
.article-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.1); }

.status-green { background-color: rgba(34,197,94,0.05) !important; border-left: 6px solid #22c55e !important; }
html.dark .status-green { background-color: rgba(34,197,94,0.1) !important; }
.status-blue { background-color: rgba(59,130,246,0.05) !important; border-left: 6px solid #3b82f6 !important; }
html.dark .status-blue { background-color: rgba(59,130,246,0.1) !important; }
.status-gray { background-color: rgba(156,163,175,0.1) !important; border-left: 6px solid #9ca3af !important; }
html.dark .status-gray { background-color: rgba(156,163,175,0.15) !important; }

/* Etiquetas */
.rpa-label {
    display: inline-block;
    background-color: #4b5563;
    color: white;
    font-size: 11px;
    font-weight: 800;
    padding: 3px 8px;
    border-radius: 4px;
    margin-bottom: 6px;
    letter-spacing: 0.05em;
}
.cat-badge {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 4px;
    margin-bottom: 6px;
    margin-left: 6px;
    letter-spacing: 0.03em;
}
.cat-1  { background: rgba(239,68,68,0.15);   color: #ef4444; }
.cat-2  { background: rgba(59,130,246,0.15);  color: #3b82f6; }
.cat-3  { background: rgba(234,179,8,0.15);   color: #ca8a04; }
.cat-4  { background: rgba(168,85,247,0.15);  color: #a855f7; }
.cat-5  { background: rgba(34,197,94,0.15);   color: #16a34a; }
.cat-6  { background: rgba(20,184,166,0.15);  color: #0d9488; }
.cat-7  { background: rgba(249,115,22,0.15);  color: #ea580c; }
.cat-8  { background: rgba(99,102,241,0.15);  color: #6366f1; }
.tipo-badge {
    display: inline-block;
    background-color: var(--border-color);
    color: var(--text-main);
    font-size: 11px;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 4px;
    margin-bottom: 6px;
    margin-left: 6px;
    letter-spacing: 0.03em;
}

/* Meta */
.article-meta { font-size: 12px; color: var(--text-sec); margin-bottom: 8px; display: flex; gap: 12px; flex-wrap: wrap; }
.article-meta span { display: flex; align-items: center; gap: 4px; }
.article-meta strong { color: var(--text-main); }
.article-title { font-size: 17px; font-weight: 700; color: var(--text-main); margin: 0 0 12px 0; line-height: 1.3; padding-right: 32px; }
.article-title a { color: inherit; text-decoration: none; }
.article-title a:hover { color: var(--accent); text-decoration: underline; }

/* Botones */
.action-buttons { display: flex; gap: 10px; margin-top: 12px; }
.btn { padding: 7px 14px; border-radius: 20px; font-size: 13px; font-weight: 700; cursor: pointer; border: none; transition: all 0.2s ease; display: inline-flex; align-items: center; gap: 6px; }
.btn-process { background-color: var(--text-main); color: var(--bg-color); }
.btn-process:hover { opacity: 0.9; transform: translateY(-1px); }
.btn-delete { background-color: transparent; color: var(--color-breaking); border: 1px solid var(--color-breaking); }
.btn-delete:hover { background-color: rgba(227,28,45,0.1); }
.btn-action-sm { padding: 5px 12px; font-size: 12px; background-color: var(--border-color); color: var(--text-main); border: none; border-radius: 6px; cursor: pointer; font-weight: 600; }
.btn-action-sm:hover { background-color: var(--card-hover); }

/* Toggle */
.btn-toggle { position: absolute; top: 14px; right: 14px; background: transparent; border: none; cursor: pointer; color: var(--text-sec); padding: 4px; border-radius: 4px; display: flex; align-items: center; justify-content: center; z-index: 2; }
.btn-toggle:hover { color: var(--text-main); background-color: var(--card-hover); }
.icon-chevron { transition: transform 0.3s ease; }
.card-minimized .icon-chevron { transform: rotate(180deg); }
.card-minimized .article-meta,
.card-minimized .action-buttons,
.card-minimized .related-list { display: none; }
.card-minimized .article-title { margin-bottom: 0; font-size: 14px; }

/* Relacionados */
.related-list { margin-top: 14px; padding-left: 18px; border-left: 2px dashed var(--border-color); display: flex; flex-direction: column; gap: 10px; }
.related-card { border-radius: 8px; padding: 12px; border: 1px solid var(--border-color); position: relative; transition: all 0.3s ease; }
.related-card .article-title { font-size: 14px; margin-bottom: 6px; }

/* Eliminado */
.card-deleted { background-color: #111 !important; border-left-color: #333 !important; color: #555 !important; opacity: 0.6; padding: 8px 16px !important; cursor: default; }
html.dark .card-deleted { background-color: #050505 !important; }
.card-deleted .article-meta, .card-deleted .action-buttons, .card-deleted .related-list, .card-deleted .btn-toggle, .card-deleted .rpa-label, .card-deleted .cat-badge, .card-deleted .tipo-badge { display: none; }
.card-deleted .article-title { color: #777 !important; text-decoration: line-through; font-size: 14px; margin: 0; display: inline-block; }
.card-deleted::before { content: 'ELIMINADO | '; color: var(--color-breaking, #e31c2d); font-size: 12px; font-weight: bold; margin-right: 8px; display: inline-block; }
.undo-btn { display: none; }
.card-deleted .undo-btn { display: inline-block; background: transparent; border: none; color: var(--accent); cursor: pointer; font-size: 12px; margin-left: 10px; text-decoration: underline; }

/* Paginado */
.pagination-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin-top: 32px;
    flex-wrap: wrap;
    margin-bottom: 20px;
}
.page-btn {
    min-width: 36px;
    height: 36px;
    border-radius: 8px;
    border: 1px solid var(--border-color);
    background: var(--bg-color);
    color: var(--text-main);
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
    display: flex; align-items: center; justify-content: center;
}
.page-btn:hover { background: var(--card-hover); }
.page-btn.active { background: var(--text-main); color: var(--bg-color); border-color: var(--text-main); }
.page-btn:disabled { opacity: 0.35; cursor: not-allowed; }
.page-info { font-size: 13px; color: var(--text-sec); font-weight: 600; padding: 0 8px; }

/* Sin resultados */
.no-results { text-align: center; padding: 40px; color: var(--text-sec); font-size: 15px; }

/* Pending Badge */
.pending-badge {
    display: inline-block;
    background-color: var(--accent);
    color: white;
    font-size: 10px;
    font-weight: 800;
    padding: 2px 6px;
    border-radius: 4px;
    margin-bottom: 6px;
    margin-left: 6px;
    vertical-align: top;
}
</style>

<!-- Auth guard overlay -->
<style>
#auth-guard-nl {
    display: flex;
    position: fixed;
    inset: 0;
    background: var(--bg-color);
    z-index: 9999;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
}
#auth-guard-nl p { font-size: 16px; color: var(--text-sec); }
#auth-guard-nl a {
    display: inline-block;
    padding: 12px 28px;
    background: var(--text-main);
    color: var(--bg-color);
    border-radius: 8px;
    font-weight: 700;
    text-decoration: none;
    transition: opacity 0.2s;
}
#auth-guard-nl a:hover { opacity: 0.85; }
#nl-page-content { display: none; }
</style>

<div id="auth-guard-nl">
    <p>🔒 Acceso restringido. Debes iniciar sesión para ver esta página.</p>
    <a href="/login/">Ir al Login</a>
</div>

<div id="nl-page-content">
<div class="curador-container">
    <div class="curador-header">
        <h1 class="curador-title">Gestión de Noticias - Agente24</h1>
        <p class="curador-subtitle">Panel de administración para procesar y moderar las noticias recopiladas.</p>
    </div>

    <div class="filters-bar" id="filtersBar">
        <div class="filter-group">
            <label for="filtroTipo">Tipo:</label>
            <select id="filtroTipo" onchange="aplicarFiltros()">
                <option value="">Todos</option>
                <option value="NUEVA">NUEVA</option>
                <option value="SEGUIMIENTO">SEGUIMIENTO</option>
            </select>
        </div>
        <div class="filter-divider"></div>
        <div class="filter-group">
            <label for="filtroEstatus">Estatus:</label>
            <select id="filtroEstatus" onchange="aplicarFiltros()">
                <option value="">Todos</option>
                <option value="nueva">Nueva (sin procesar)</option>
                <option value="procesada">Procesada</option>
            </select>
        </div>
        <div class="filter-divider"></div>
        <div class="filter-group">
            <label for="filtroRpa">Estatus RPA:</label>
            <select id="filtroRpa" onchange="aplicarFiltros()">
                <option value="">Todos</option>
                <option value="si">Procesado RPA</option>
                <option value="no">Sin procesar RPA</option>
            </select>
        </div>
        <div class="filter-divider"></div>
        <div class="filter-group">
            <label for="filtroEliminados">Eliminados:</label>
            <select id="filtroEliminados" onchange="aplicarFiltros()">
                <option value="ocultar" selected>Ocultar (Default)</option>
                <option value="mostrar">Mostrar todos</option>
                <option value="solo">Solo eliminados</option>
            </select>
        </div>
        <div class="filter-divider"></div>
        <div class="filter-group">
            <label for="filtroCategoria">Categoría:</label>
            <select id="filtroCategoria" onchange="aplicarFiltros()">
                <option value="">Todas</option>
                <option value="1">Deportes</option>
                <option value="2">Tecnología</option>
                <option value="3">Negocios</option>
                <option value="4">Entretenimiento</option>
                <option value="5">México</option>
                <option value="6">Salud</option>
                <option value="7">Internacionales</option>
                <option value="8">Ciencia</option>
            </select>
        </div>
        <div class="filter-divider"></div>
        <button class="btn-action-sm" onclick="colapsarTodos()">⬆ Colapsar</button>
        <button class="btn-action-sm" onclick="maximizarTodos()">⬇ Expandir</button>
        <button class="btn-action-sm" onclick="fetchNoticias()">🔄 Refrescar</button>
        <button class="btn-action-sm" onclick="resetFiltros()">✕ Limpiar</button>
    </div>
    
    <div id="actionBarContainer" style="display: none;"></div>

    <div class="article-list" id="articleList">
        <div class="no-results">Cargando noticias...</div>
    </div>
    <div class="pagination-bar" id="paginationBar"></div>
</div>

<script>
const API_BASE = "{{ site.apiBase }}";
const PAGE_SIZE = 10;
let currentPage = 1;
let allArticles = [];

const CAT_NAMES = {
    1: 'Deportes', 2: 'Tecnología', 3: 'Negocios', 4: 'Entretenimiento',
    5: 'México', 6: 'Salud', 7: 'Internacionales', 8: 'Ciencia'
};

// Estado visual: minimizado (por id de div)
const cardState = {};

// Estado de cambios pendientes: { 'id': { procesada?: boolean, eliminado?: boolean } }
let pendingChanges = {
    articulos: {},
    relacionados: {}
};

// ---- CORE DATA FETCH ----
async function fetchNoticias() {
    const list = document.getElementById('articleList');
    list.innerHTML = '<div class="no-results">Cargando noticias...</div>';
    
    // Obtener filtros
    const tipo = document.getElementById('filtroTipo').value;
    const estatus = document.getElementById('filtroEstatus').value;
    const rpa = document.getElementById('filtroRpa').value;
    const eliminados = document.getElementById('filtroEliminados').value;
    const categoria = document.getElementById('filtroCategoria').value;

    const params = new URLSearchParams();
    
    if (tipo) params.append('tipo', tipo);
    
    if (estatus === 'nueva') {
        params.append('procesada', 'false');
        params.append('procesado_rpa', 'false');
    } else if (estatus === 'procesada') {
        params.append('procesada', 'true');
    }

    if (rpa === 'si') params.append('procesado_rpa', 'true');
    else if (rpa === 'no') params.append('procesado_rpa', 'false');

    if (eliminados === 'ocultar') params.append('eliminado', 'false');
    else if (eliminados === 'solo') params.append('eliminado', 'true');
    // Si es "mostrar", no enviamos param

    if (categoria) params.append('categoria_id', categoria);

    try {
        const url = `${API_BASE}/api/v1/noticias?${params.toString()}`;
        const res = await fetch(url);
        const json = await res.json();
        
        if (json.success || json.data) {
            allArticles = Array.isArray(json.data) ? json.data : json;
            currentPage = 1;
            renderPage();
            updateStickyBar();
        } else {
            list.innerHTML = `<div class="no-results">Error al cargar datos. <button class="btn-action-sm" onclick="fetchNoticias()">Reintentar</button></div>`;
        }
    } catch (e) {
        list.innerHTML = `<div class="no-results">Error de red o conexión. <br><br>URL: ${API_BASE}/api/v1/noticias<br><br><button class="btn-action-sm" onclick="fetchNoticias()">Reintentar</button></div>`;
        console.error(e);
    }
}

// ---- RENDERING ----
function catBadge(catId) {
    if (!catId) return '';
    const name = CAT_NAMES[catId] || ('Cat ' + catId);
    return `<span class="cat-badge cat-${catId}">${name}</span>`;
}

function getArtStatus(art, isRelated) {
    const pChanges = isRelated ? pendingChanges.relacionados : pendingChanges.articulos;
    const id = isRelated ? art.relacionado_id : art.articulo_id;
    
    let isProcesada = art.procesada;
    let isEliminado = art.eliminado;
    let isPending = false;

    if (pChanges[id]) {
        if (pChanges[id].procesada !== undefined) isProcesada = pChanges[id].procesada;
        if (pChanges[id].eliminado !== undefined) isEliminado = pChanges[id].eliminado;
        isPending = true;
    }

    let cssClass = 'status-green';
    if (art.procesado_rpa) cssClass = 'status-gray';
    else if (isProcesada) cssClass = 'status-blue';

    return { isProcesada, isEliminado, isPending, cssClass };
}

function renderRelated(rel, parentEliminado) {
    // Si padre eliminado y esto se renderiza (solo por precaución, no debería llamarse)
    if (parentEliminado) return '';

    const status = getArtStatus(rel, true);
    const rid = 'related-' + rel.relacionado_id;
    const st = cardState[rid] || {};
    
    // Si la UI lo minimizó
    let finalClass = status.cssClass;
    if (status.isEliminado) finalClass += ' card-deleted';

    return `
    <div class="related-card ${finalClass}" id="${rid}">
        ${rel.procesado_rpa ? '<span class="rpa-label">PROCESADO RPA</span>' : ''}
        ${status.isPending ? '<span class="pending-badge">MODIFICADO</span>' : ''}
        <div class="article-meta">
            <span><strong>ID:</strong> ${rel.relacionado_id}</span>
            <span><strong>Fuente:</strong> ${rel.fuente || '—'}</span>
            ${rel.status ? `<span><strong>Status:</strong> ${rel.status}</span>` : ''}
        </div>
        <h3 class="article-title">${rel.titulo}</h3>
        <div class="action-buttons">
            ${!rel.procesado_rpa && !status.isEliminado ? `
            <button class="btn btn-process" onclick="event.stopPropagation();toggleItemProcesar(${rel.relacionado_id}, true)">
                <span class="btn-text">${status.isProcesada ? 'Desprocesar' : 'Procesar'}</span>
            </button>` : ''}
            ${!status.isEliminado ? `
            <button class="btn btn-delete" onclick="event.stopPropagation();eliminarItem(${rel.relacionado_id}, true)">Eliminar</button>` : ''}
        </div>
        ${status.isEliminado ? `<button class="undo-btn" onclick="event.stopPropagation();deshacerEliminar(${rel.relacionado_id}, true)">Deshacer Eliminado</button>` : ''}
    </div>`;
}

function renderArticle(art) {
    const aid = 'article-' + art.articulo_id;
    const status = getArtStatus(art, false);
    const st = cardState[aid] || {};
    
    // Relacionados solo si el padre NO está eliminado
    let relatedHtml = '';
    if (!status.isEliminado && art.articulos_relacionados && art.articulos_relacionados.length > 0) {
        relatedHtml = `<div class="related-list">` + art.articulos_relacionados.map(r => renderRelated(r, status.isEliminado)).join('') + `</div>`;
    }

    let finalClass = status.cssClass;
    if (st.minimized) finalClass += ' card-minimized';
    if (status.isEliminado) finalClass += ' card-deleted';

    return `
    <div class="article-card ${finalClass}" id="${aid}" onclick="handleCardClick(event, '${aid}')">
        <button class="btn-toggle" onclick="event.stopPropagation();toggleCard('${aid}')" title="Minimizar/Maximizar">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-chevron"><polyline points="18 15 12 9 6 15"></polyline></svg>
        </button>

        ${art.procesado_rpa ? '<span class="rpa-label">PROCESADO RPA</span>' : ''}
        ${catBadge(art.categoria_id)}
        ${art.tipo ? `<span class="tipo-badge">${art.tipo}</span>` : ''}
        ${status.isPending ? '<span class="pending-badge">MODIFICADO</span>' : ''}

        <div class="article-meta">
            <span><strong>ID:</strong> ${art.articulo_id}</span>
            <span><strong>Fuente:</strong> ${art.fuente_principal || '—'}</span>
            <span><strong>Fecha:</strong> ${art.fecha_publicacion ? art.fecha_publicacion.substring(0,10) : '—'}</span>
        </div>

        <h2 class="article-title">${art.titulo}</h2>

        <div class="action-buttons">
            ${!art.procesado_rpa && !status.isEliminado ? `
            <button class="btn btn-process" onclick="event.stopPropagation();toggleItemProcesar(${art.articulo_id}, false)">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                <span class="btn-text">${status.isProcesada ? 'Desprocesar' : 'Procesar'}</span>
            </button>` : ''}
            ${!status.isEliminado ? `
            <button class="btn btn-delete" onclick="event.stopPropagation();eliminarItem(${art.articulo_id}, false)">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                Eliminar
            </button>` : ''}
        </div>

        ${relatedHtml}
        ${status.isEliminado ? `<button class="undo-btn" onclick="event.stopPropagation();deshacerEliminar(${art.articulo_id}, false)">Deshacer Eliminado</button>` : ''}
    </div>`;
}

function renderPage() {
    const list = document.getElementById('articleList');
    const pagBar = document.getElementById('paginationBar');
    
    const total = allArticles.length;
    const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
    currentPage = Math.min(currentPage, totalPages);

    const start = (currentPage - 1) * PAGE_SIZE;
    const pageItems = allArticles.slice(start, start + PAGE_SIZE);

    if (pageItems.length === 0) {
        list.innerHTML = '<div class="no-results">No se encontraron artículos con los filtros aplicados.</div>';
        pagBar.innerHTML = '';
        return;
    }

    list.innerHTML = pageItems.map(renderArticle).join('');

    // Paginación
    let pag = '';
    pag += `<button class="page-btn" onclick="goPage(${currentPage-1})" ${currentPage===1?'disabled':''}>‹</button>`;
    for (let i = 1; i <= totalPages; i++) {
        if (totalPages > 9 && i > 3 && i < totalPages - 2 && Math.abs(i - currentPage) > 1) {
            if (i === 4 || i === totalPages - 3) pag += `<span class="page-info">…</span>`;
            continue;
        }
        pag += `<button class="page-btn ${i===currentPage?'active':''}" onclick="goPage(${i})">${i}</button>`;
    }
    pag += `<button class="page-btn" onclick="goPage(${currentPage+1})" ${currentPage===totalPages?'disabled':''}>›</button>`;
    pag += `<span class="page-info">${total} artículos</span>`;
    pagBar.innerHTML = pag;
}

function goPage(n) {
    const totalPages = Math.max(1, Math.ceil(allArticles.length / PAGE_SIZE));
    if (n < 1 || n > totalPages) return;
    currentPage = n;
    renderPage();
    window.scrollTo({ top: 0, behavior: 'smooth' });
}

function aplicarFiltros() {
    fetchNoticias();
}

function resetFiltros() {
    document.getElementById('filtroTipo').value = '';
    document.getElementById('filtroEstatus').value = '';
    document.getElementById('filtroRpa').value = '';
    document.getElementById('filtroEliminados').value = 'ocultar';
    document.getElementById('filtroCategoria').value = '';
    fetchNoticias();
}

// ---- INTERACTIVIDAD UI ----
function handleCardClick(event, id) {
    const tag = event.target.tagName.toLowerCase();
    if (['button','a','input','select','label'].includes(tag)) return;
    if (event.target.closest('button, a, input, select, .undo-btn')) return;
    const el = document.getElementById(id);
    if (!el || el.classList.contains('card-deleted')) return;
    toggleCard(id);
}

function toggleCard(id) {
    const el = document.getElementById(id);
    if (!el) return;
    el.classList.toggle('card-minimized');
    if (!cardState[id]) cardState[id] = {};
    cardState[id].minimized = el.classList.contains('card-minimized');
}

function colapsarTodos() {
    document.querySelectorAll('.article-card:not(.card-deleted)').forEach(el => {
        el.classList.add('card-minimized');
        if (!cardState[el.id]) cardState[el.id] = {};
        cardState[el.id].minimized = true;
    });
}

function maximizarTodos() {
    document.querySelectorAll('.article-card').forEach(el => {
        el.classList.remove('card-minimized');
        if (!cardState[el.id]) cardState[el.id] = {};
        cardState[el.id].minimized = false;
    });
}

// ---- PENDING CHANGES LOGIC ----
function findOriginalArticle(id, isRelated) {
    if (!isRelated) return allArticles.find(a => a.articulo_id === id);
    for (const a of allArticles) {
        if (a.articulos_relacionados) {
            const rel = a.articulos_relacionados.find(r => r.relacionado_id === id);
            if (rel) return rel;
        }
    }
    return null;
}

function toggleItemProcesar(id, isRelated) {
    const pChanges = isRelated ? pendingChanges.relacionados : pendingChanges.articulos;
    const original = findOriginalArticle(id, isRelated);
    if (!original) return;

    if (!pChanges[id]) pChanges[id] = {};
    
    // Toggle current state
    const currentProcesada = pChanges[id].procesada !== undefined ? pChanges[id].procesada : original.procesada;
    pChanges[id].procesada = !currentProcesada;

    // Si vuelve a ser igual que el original, y no hay otro flag modificado, quitamos la key
    if (pChanges[id].procesada === original.procesada && pChanges[id].eliminado === undefined) {
        delete pChanges[id];
    }

    renderPage();
    updateStickyBar();
}

function eliminarItem(id, isRelated) {
    const pChanges = isRelated ? pendingChanges.relacionados : pendingChanges.articulos;
    if (!pChanges[id]) pChanges[id] = {};
    pChanges[id].eliminado = true;
    renderPage();
    updateStickyBar();
}

function deshacerEliminar(id, isRelated) {
    const pChanges = isRelated ? pendingChanges.relacionados : pendingChanges.articulos;
    if (pChanges[id]) {
        delete pChanges[id].eliminado;
        if (Object.keys(pChanges[id]).length === 0) {
            delete pChanges[id];
        }
    }
    renderPage();
    updateStickyBar();
}

function descartarCambios() {
    pendingChanges = { articulos: {}, relacionados: {} };
    renderPage();
    updateStickyBar();
}

// ---- STICKY BAR & API PATCH ----
function updateStickyBar() {
    const bar = document.getElementById('actionBarContainer');
    if (!bar) return;
    
    const countArt = Object.keys(pendingChanges.articulos).length;
    const countRel = Object.keys(pendingChanges.relacionados).length;
    const total = countArt + countRel;

    bar.style.display = 'flex';
    bar.style.cssText = `
        background: var(--card-hover);
        border: 2px solid var(--accent); border-radius: 12px;
        padding: 16px; margin-bottom: 24px; width: 100%;
        display: flex; align-items: center; justify-content: center;
    `;
    
    const isBtnDisabled = total === 0 ? 'disabled style="opacity: 0.5; cursor: not-allowed;' : 'style="cursor: pointer;';
    
    bar.innerHTML = `
        <div style="display:flex; justify-content:space-between; align-items:center; width:100%; flex-wrap:wrap; gap:12px;">
            <div style="font-size:14px; font-weight:600;">
                📋 Cambios pendientes: <span style="color:var(--accent)">${countArt} artículos</span> · <span style="color:var(--accent)">${countRel} relacionados</span>
            </div>
            <div style="display:flex; gap:10px;">
                <button onclick="descartarCambios()" ${isBtnDisabled} padding:8px 16px; border:1px solid var(--border-color); background:transparent; border-radius:20px; color:var(--text-main); font-weight:700;">Descartar</button>
                <button id="btnProcesarCambios" onclick="procesarCambiosBackend()" ${isBtnDisabled} padding:8px 16px; border:none; background:var(--accent); border-radius:20px; color:#fff; font-weight:700;">✓ Procesar Cambios</button>
            </div>
        </div>
    `;
}

async function procesarCambiosBackend() {
    const btn = document.getElementById('btnProcesarCambios');
    if (btn) {
        btn.innerText = 'Procesando...';
        btn.disabled = true;
        btn.style.opacity = '0.7';
    }

    const payloadArt = Object.keys(pendingChanges.articulos).map(id => {
        return { articulo_id: parseInt(id), ...pendingChanges.articulos[id] };
    });

    const payloadRel = Object.keys(pendingChanges.relacionados).map(id => {
        return { relacionado_id: parseInt(id), ...pendingChanges.relacionados[id] };
    });

    try {
        let okArts = 0, errArts = 0;
        let okRels = 0, errRels = 0;

        // PATCH Artículos
        if (payloadArt.length > 0) {
            const resA = await fetch(`${API_BASE}/api/v1/noticias/articulo`, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payloadArt)
            });
            const jsonA = await resA.json();
            if (jsonA.success && jsonA.data) {
                okArts = jsonA.data.exitosos || 0;
                errArts = jsonA.data.errores || 0;
            } else {
                errArts = payloadArt.length; // asume todos fallaron
            }
        }

        // PATCH Relacionados
        if (payloadRel.length > 0) {
            const resR = await fetch(`${API_BASE}/api/v1/noticias/articulo-relacionado`, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payloadRel)
            });
            const jsonR = await resR.json();
            if (jsonR.success && jsonR.data) {
                okRels = jsonR.data.exitosos || 0;
                errRels = jsonR.data.errores || 0;
            } else {
                errRels = payloadRel.length;
            }
        }

        alert(`PROCESO FINALIZADO:\n\nArtículos: ${okArts} exitosos, ${errArts} errores.\nRelacionados: ${okRels} exitosos, ${errRels} errores.`);
        
        // Limpiar y recargar
        pendingChanges = { articulos: {}, relacionados: {} };
        updateStickyBar();
        fetchNoticias();

    } catch (err) {
        console.error(err);
        alert('Ocurrió un error de red al procesar los cambios.');
        if (btn) {
            btn.innerText = '✓ Procesar Cambios';
            btn.disabled = false;
            btn.style.opacity = '1';
        }
    }
}

// Botón "ir arriba" — inyectado en body
(function() {
    const btn = document.createElement('button');
    btn.id = 'btnTop';
    btn.title = 'Ir arriba';
    btn.innerHTML = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"></polyline></svg>';
    btn.style.cssText = 'position:fixed;bottom:90px;right:24px;width:44px;height:44px;border-radius:50%;background:var(--text-main);color:var(--bg-color);border:none;cursor:pointer;display:none;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(0,0,0,0.3);z-index:9999;transition:all 0.2s;';
    btn.onclick = () => window.scrollTo({ top: 0, behavior: 'smooth' });
    document.body.appendChild(btn);

    window.addEventListener('scroll', () => {
        if (window.scrollY > 300) btn.style.display = 'flex';
        else btn.style.display = 'none';
    });
})();

// INIT - se llama desde el guard de auth cuando el usuario está autenticado
window._initNoticiaslista = fetchNoticias;
</script>

