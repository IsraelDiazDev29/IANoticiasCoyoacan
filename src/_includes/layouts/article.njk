---
layout: layouts/base.njk
ogType: article
---


<article class="max-w-3xl mx-auto px-4 py-6 space-y-6">
  <header class="space-y-3">
    <div class="aspect-video relative rounded-2xl overflow-hidden">
      <img src="{{ cover }}" alt="{{ alt or title }}" class="w-full h-full object-cover" fetchpriority="high" width="1200" height="630">
      {% if breaking %}
      <span class="absolute top-3 left-3 bg-magenta-500 text-white text-xs px-2 py-1 rounded">BREAKING</span>
      {% endif %}
    </div>
    <h1 style="font-family: var(--font-headline); font-size: 2rem; font-weight: 700; line-height: 1.25; color: inherit;">{{ title }}</h1>
    {% include "partials/meta-row.njk" %}
  </header>
{% include "partials/admin-bar.njk" %}

  <div style="font-family: var(--font-body); font-size: 1.0625rem; line-height: 1.75; max-width: 65ch;">
    {{ content | safe }}
  </div>

  <!-- JSON-LD NewsArticle -->
  <script type="application/ld+json">
  {
    "@context":"https://schema.org",
    "@type":"NewsArticle",
    "inLanguage":"es-MX",
    "headline":"{{ title }}",
    "description":"{{ description or site.description }}",
    "image":[ "{{ site.url }}{{ cover }}" ],
    "datePublished":"{{ page.date | dateIso }}",
    "dateModified":"{{ (modified or page.date) | dateIso }}",
    "mainEntityOfPage": { "@type":"WebPage", "@id":"{{ site.url }}{{ page.url }}" },
    "author": { "@type":"Person", "name":"{{ author }}" },
    "publisher": {
      "@type":"NewsMediaOrganization",
      "name":"{{ site.name }}",
      "logo": { "@type":"ImageObject", "url":"{{ site.url }}{{ site.logo }}" }
    },
    "articleSection":"{{ category }}",
    "keywords":"{% if tags %}{{ tags | join(', ') }}{% endif %}"
  }
  </script>
</article>
