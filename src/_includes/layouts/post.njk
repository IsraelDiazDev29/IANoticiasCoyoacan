---
layout: layouts/base.njk
hideHeader: true
hideFooter: true
---
<div class="relative flex w-full min-h-screen flex-col justify-between overflow-x-hidden bg-white text-[#121417]">
  <div>
    <div class="flex items-center bg-white p-4 pb-2 justify-between border-b border-gray-100">
      <div class="flex-1 flex flex-col items-center pl-12">
        <img src="/assets/logo.webp" alt="Logo" class="w-8 h-8 mb-1 object-contain" />
        <div class="text-[#111418] text-lg font-bold text-center">IA NOTICIAS COYOACAN</div>
      </div>
      <div class="flex w-12 items-center justify-end">
        <a href="/" class="cursor-pointer h-12 flex items-center justify-center rounded-lg bg-transparent text-[#111418]">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 256 256"><path d="M224,128a8,8,0,0,1-8,8H40a8,8,0,0,1,0-16H216A8,8,0,0,1,224,128ZM40,72H216a8,8,0,0,0,0-16H40a8,8,0,0,0,0,16ZM216,184H40a8,8,0,0,0,0,16H216a8,8,0,0,0,0-16Z"/></svg>
        </a>
      </div>
    </div>

    <div class="px-4 pt-6 pb-3">
       <div id="trend-badge-container" class="hidden mb-2">
         <span style="background-color: var(--color-breaking);" class="text-white text-[10px] font-bold px-2 py-0.5 rounded uppercase tracking-wide">TENDENCIA</span>
       </div>
       
       {% if category %}
       <div style="margin-bottom: 12px;">
         <a href="/categoria/{{ category | slugify }}/" style="display: inline-block; padding: 4px 12px; background-color: rgba(37, 99, 235, 0.1); color: var(--accent, #1d9bf0); font-size: 12px; font-weight: bold; border-radius: 4px; border: 1px solid rgba(37, 99, 235, 0.2); text-transform: uppercase; letter-spacing: 0.05em; text-decoration: none;">
           {{ category }}
         </a>
       </div>
       {% endif %}

       <h1 style="font-family: var(--font-headline); font-size: 2rem; font-weight: 700; line-height: 1.2; color: #121417; margin: 0;">{{ title }}</h1>
        {% if author %}
          {% set authorData = authors[author] %}
          {% if authorData %}
            <div style="margin-top: 16px; display: flex; align-items: center; gap: 12px; flex-wrap: wrap;">
              <a href="/autor/{{ author }}/" style="display: inline-flex; align-items: center; gap: 8px; padding: 4px 16px 4px 4px; background-color: var(--card-hover); border-radius: 30px; text-decoration: none; font-size: 14.5px; font-weight: 700; color: inherit;">
                <img src="{{ authorData.avatar }}" alt="{{ authorData.name }}" style="width: 28px; height: 28px; border-radius: 50%; object-fit: cover;" />
                <span>Por {{ authorData.name }}</span>
              </a>
              <span style="font-size: 13.5px; color: var(--text-sec); font-family: var(--font-ui); font-weight: 500;">
                {{ page.date | dateReadable }}
              </span>
            </div>
          {% endif %}
        {% endif %}
    </div>

    {% if image %}
    <div class="flex w-full bg-white py-1">
     <div class="w-full overflow-hidden relative" style="aspect-ratio: 3/2;">
        <img src="{{ image }}" alt="{{ title }}" class="w-full h-full object-cover" fetchpriority="high" width="1200" height="800">
       </div>
    </div>
    {% endif %}

    <div style="font-family: var(--font-body); font-size: 1.0625rem; line-height: 1.7; padding: 1rem 1rem 3rem; color: #121417; max-width: 100%;">
        {{ content | safe }}
    </div>
  </div>
</div>

<script>
  (function() {
    var postDate = "{{ page.date | dateIso }}"; 
    var now = new Date();
    var todayString = now.toISOString().split('T')[0]; // Forma más corta de sacar YYYY-MM-DD
    if (postDate === todayString) {
      var badge = document.getElementById("trend-badge-container");
      if (badge) badge.classList.remove('hidden');
    }
  })();
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  "inLanguage": "es-MX",
  "headline": "{{ title }}",
  "description": "{{ description or site.description }}",
  "image": ["{{ site.url }}{{ image }}"],
  "datePublished": "{{ page.date | dateIso }}",
  "dateModified": "{{ page.date | dateIso }}",
  "mainEntityOfPage": { "@type": "WebPage", "@id": "{{ site.url }}{{ page.url }}" },
  "author": { "@type": "Person", "name": "{% if authors and author and authors[author] %}{{ authors[author].name }}{% else %}{{ author or site.publisher.name }}{% endif %}" },
  "publisher": {
    "@type": "NewsMediaOrganization",
    "name": "{{ site.name }}",
    "logo": { "@type": "ImageObject", "url": "{{ site.url }}{{ site.logo }}" }
  }
}
</script>