<div class="text-sm opacity-80" style="display: flex; flex-wrap: wrap; align-items: center; gap: 12px;">
  <time datetime="{{ page.date | dateIso }}">{{ page.date | dateReadable }}</time>
  
  {% if author and authors[author] %}
    <a href="/autor/{{ author }}/" style="display: inline-flex; align-items: center; gap: 6px; padding: 2px 8px 2px 2px; background-color: var(--card-hover); border-radius: 20px; font-weight: 600; text-decoration: none; color: inherit;">
      <img src="{{ authors[author].avatar }}" style="width: 20px; height: 20px; border-radius: 50%; object-fit: cover;" />
      {{ authors[author].name }}
    </a>
  {% elif author %}
    <span style="display: inline-flex; align-items: center; padding: 4px 8px; background-color: rgba(148, 163, 184, 0.1); border-radius: 6px;">{{ author }}</span>
  {% endif %}
  
  <a href="/categoria/{{ category | slugify }}/" style="display: inline-flex; align-items: center; padding: 4px 8px; background-color: rgba(37, 99, 235, 0.1); color: var(--accent, #1d9bf0); border-radius: 6px; font-weight: 500; border: 1px solid rgba(37, 99, 235, 0.2); text-decoration: none;">
    <svg style="width: 14px; height: 14px; margin-right: 4px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
    {{ category }}
  </a>
</div>
