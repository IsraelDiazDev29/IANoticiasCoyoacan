<article class="tweet-card">
  <a href="{{ post.url }}" style="display: flex; width: 100%; text-decoration: none; color: inherit;">
    
    <div class="tweet-avatar-col">
      {% set cat = post.data.category | default("General") | lower %}
      {% if cat == "tendencias" %}
        <img src="/assets/logos/tendencias.webp" alt="Tendencias" class="avatar-circle" style="width: 40px !important; height: 40px !important; max-width: 40px !important; margin: 0 !important; border-radius: 50%; object-fit: cover; background: #ffffff; display: block;">
      {% elif cat == "nacionales" or cat == "nacional" %}
        <img src="/assets/logos/nacionales.webp" alt="Nacionales" class="avatar-circle" style="width: 40px !important; height: 40px !important; max-width: 40px !important; margin: 0 !important; border-radius: 50%; object-fit: cover; background: #ffffff; display: block;">
      {% elif cat == "deportes" %}
        <img src="/assets/logos/deportes.webp" alt="Deportes" class="avatar-circle" style="width: 40px !important; height: 40px !important; max-width: 40px !important; margin: 0 !important; border-radius: 50%; object-fit: cover; background: #ffffff; display: block;">
      {% else %}
        <div class="avatar-circle">NC</div>
      {% endif %}
    </div>

    <div class="tweet-content-col">
      
      <div class="tweet-header">
        <span class="user-name">{{ post.data.category | default("General") }}</span>
        <span class="user-handle">@NoticiasCoyo</span>
        <span class="tweet-dot">·</span>
        <time class="tweet-time">{{ post.date | dateReadable }}</time>
      </div>

      <div class="tweet-title">
         {{ post.data.title }}
      </div>

      {% if post.data.summary %}
      <div class="tweet-text">
        {{ post.data.summary }}
      </div>
      {% endif %}

      <div class="tweet-media">
        <div class="media-aspect-ratio">
        {% if post.data.cover %}
                <img src="{{ post.data.cover }}" alt="{{ post.data.alt or post.data.title }}" class="media-img" loading="lazy" width="600" height="338">
            {% elif post.data.image %}
                <img src="{{ post.data.image }}" alt="{{ post.data.alt or post.data.title }}" class="media-img" loading="lazy" width="600" height="338">
            {% elif post.data.youtubeId %}
                <img src="https://img.youtube.com/vi/{{ post.data.youtubeId }}/hqdefault.jpg" alt="Video: {{ post.data.title }}" class="media-img" loading="lazy" width="480" height="360">
                <div style="position:absolute; inset:0; display:flex; align-items:center; justify-content:center; background:rgba(0,0,0,0.3);">
                    <div style="width:40px; height:40px; background:white; border-radius:50%; display:flex; align-items:center; justify-content:center;">▶</div>
                </div>
            {% else %}
                 <div style="position:absolute; inset:0; display:flex; align-items:center; justify-content:center; color:#555;">Sin imagen</div>
            {% endif %}
        </div>
      </div>

      <div class="tweet-actions">
         <div class="action-item">
            <span>Leer más</span>
         </div>
         <div class="action-item">
            <span>Compartir</span>
         </div>
      </div>

    </div>
  </a>
</article>